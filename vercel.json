{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/handler"
    }
  ],
  "functions": {
    "api/handler.js": {
      "includeFiles": "dist/server/**"
    }
  }
}
